&lt;blockquote>
&lt;p>💡 Tip profesional: Usa oscap para evaluar automáticamente el cumplimiento CIS:&lt;/p>
&lt;div class="highlight">&lt;div class="chroma">
&lt;table class="lntable">&lt;tr>&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code>&lt;span class="lnt">1
&lt;/span>&lt;span class="lnt">2
&lt;/span>&lt;/code>&lt;/pre>&lt;/td>
&lt;td class="lntd">
&lt;pre tabindex="0" class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="line">&lt;span class="cl">sudo dnf install openscap-scanner -y
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sudo oscap xccdf &lt;span class="nb">eval&lt;/span> --profile cis_level2 /usr/share/xml/scap/ssg/content/ssg-almalinux9-ds.xml
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/td>&lt;/tr>&lt;/table>
