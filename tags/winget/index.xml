&lt;div class=&#34;ratio ratio-16x9 embed-video&#34;&gt;
	&lt;iframe
		src=&#39;https://www.youtube.com/embed/3WT-dPSifOw?rel=0&#39;
		title=&#34;Video de Youtube&#34;
		allowfullscreen&gt;
	&lt;/iframe&gt;
